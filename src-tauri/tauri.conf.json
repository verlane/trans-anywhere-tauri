{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TransAnywhere",
  "mainBinaryName": "TransAnywhere",
  "version": "0.1.0",
  "identifier": "com.song.transanywhere",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TransAnywhere",
        "width": 460,
        "height": 640,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
